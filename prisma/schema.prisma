generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model event_logs {
  log_id    Int     @id @db.SmallInt
  log_date  String? @db.VarChar(26)
  log_event String? @db.VarChar(61)
}

model mobile_suits {
  ms_id                 Int                     @id @db.SmallInt
  ms_mid                String?                 @db.VarChar(14)
  ms_name               String?                 @db.VarChar(30)
  ms_pic                String?                 @db.VarChar(90)
  ms_cost               Int?
  ms_armor              Int?
  ms_level              Int?                    @db.SmallInt
  ms_exp                Int?                    @db.SmallInt
  ms_atk1               String?                 @db.VarChar(31)
  ms_atk2               String?                 @db.VarChar(28)
  ms_atk3               String?                 @db.VarChar(28)
  ms_basicAtkdmg        Int?                    @db.SmallInt
  ms_atk1dmg            Int?                    @db.SmallInt
  ms_atk2dmg            Int?
  ms_atk3dmg            Int?
  ms_atk1Eff            String?                 @db.VarChar(9)
  ms_atk2Eff            String?                 @db.VarChar(9)
  ms_atk3Eff            String?                 @db.VarChar(9)
  user_has_mobile_suits user_has_mobile_suits[]
}

model user {
  u_id                  Int                     @id @db.SmallInt
  u_name                String?                 @db.VarChar(14)
  u_account             String?                 @unique @db.VarChar(255)
  u_password            Int?
  u_email               String?                 @unique @db.VarChar(255)
  u_points              Int?
  u_type                String?                 @db.VarChar(5)
  u_status              String?                 @db.VarChar(3)
  user_has_mobile_suits user_has_mobile_suits[]
}

model user_has_mobile_suits {
  u_id            Int          @db.SmallInt
  ms_id           Int          @db.SmallInt
  ums_armor       Int?         @db.SmallInt
  ums_level       Int?         @db.SmallInt
  ums_exp         Int?
  ums_basicAtkdmg Int?         @db.SmallInt
  ums_atk1dmg     Int?         @db.SmallInt
  ums_atk2dmg     Int?         @db.SmallInt
  ums_atk3dmg     Int?         @db.SmallInt
  ums_onLineup    String?      @db.VarChar(3)
  mobile_suits    mobile_suits @relation(fields: [ms_id], references: [ms_id])
  user            user         @relation(fields: [u_id], references: [u_id])

  @@id([u_id, ms_id])
}
